digraph addExpenseCFG {
    rankdir=TB;
    bgcolor="white";
    node [fontname="Arial", fontsize=10, style=filled];
    edge [fontname="Arial", fontsize=9];

    Start [shape=ellipse, label="START", fillcolor="#C8E6C9"];
    n1 [shape=box, label="getOrCreateWalletOwnedByUser(tripId, login)", fillcolor="#FFF9C4"];
    n2 [shape=diamond, label="amount == null\nsau\namount <= 0 ?", fillcolor="#FFCCBC"];
    n3 [shape=box, label="throw IllegalArgumentException\n\"Suma trebuie sa fie > 0\"", fillcolor="#FFAB91"];
    n4 [shape=box, label="safeTitle = title.trim()", fillcolor="#FFF9C4"];
    n5 [shape=diamond, label="safeTitle.isBlank() ?", fillcolor="#FFCCBC"];
    n6 [shape=box, label="throw IllegalArgumentException\n\"Titlul este obligatoriu\"", fillcolor="#FFAB91"];
    n7 [shape=diamond, label="dayIndex != null\nși\ndayIndex <= 0 ?", fillcolor="#FFCCBC"];
    n8 [shape=box, label="throw IllegalArgumentException\n\"Ziua trebuie sa fie >= 1\"", fillcolor="#FFAB91"];
    n9 [shape=box, label="tx = new WalletTransaction()\nsetare câmpuri (amount, title, ...)", fillcolor="#FFF9C4"];
    n10 [shape=box, label="walletTransactionRepository.save(tx)", fillcolor="#FFF9C4"];
    End [shape=ellipse, label="END", fillcolor="#C8E6C9"];

    Start -> n1;
    n1 -> n2;
    n2 -> n3 [label="TRUE", color="#D32F2F"];
    n2 -> n4 [label="FALSE", color="#388E3C"];
    n3 -> End;
    n4 -> n5;
    n5 -> n6 [label="TRUE", color="#D32F2F"];
    n5 -> n7 [label="FALSE", color="#388E3C"];
    n6 -> End;
    n7 -> n8 [label="TRUE", color="#D32F2F"];
    n7 -> n9 [label="FALSE", color="#388E3C"];
    n8 -> End;
    n9 -> n10;
    n10 -> End;
}
