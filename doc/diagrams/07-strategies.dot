digraph strategies {
    rankdir=TB;
    bgcolor="white";
    node [fontname="Arial", fontsize=11, style="filled,rounded", shape=box];
    edge [fontname="Arial", fontsize=10];

    Tests [label="Testarea unitară\nWalletServiceImpl", fillcolor="#1976D2", color="#0D47A1", fontcolor=white, penwidth=2, shape=oval];

    BB [label="Black Box\n(testare funcțională)", fillcolor="#26A69A", fontcolor=white, color="#004D40"];
    WB [label="White Box\n(testare structurală)", fillcolor="#7E57C2", fontcolor=white, color="#311B92"];

    EP [label="Equivalence\nPartitioning\n(9 teste)", fillcolor="#80CBC4"];
    BVA [label="Boundary Value\nAnalysis\n(10 teste)", fillcolor="#80CBC4"];

    SC [label="Statement\nCoverage\n(3 teste)", fillcolor="#B39DDB"];
    DC [label="Decision\nCoverage\n(2 teste)", fillcolor="#B39DDB"];
    CC [label="Condition\nCoverage\n(7 teste)", fillcolor="#B39DDB"];
    BP [label="Basis Path /\nCircuits\n(3 teste)", fillcolor="#B39DDB"];

    MUT [label="Mutation Testing\n(PITest)", fillcolor="#FF7043", fontcolor=white, color="#BF360C"];

    Tests -> BB;
    Tests -> WB;
    Tests -> MUT;

    BB -> EP;
    BB -> BVA;

    WB -> SC;
    WB -> DC;
    WB -> CC;
    WB -> BP;

    SC -> DC [style=dashed, label="extinde", fontcolor="#666666"];
    DC -> CC [style=dashed, label="extinde", fontcolor="#666666"];
    CC -> BP [style=dashed, label="extinde", fontcolor="#666666"];
}
